<section class="form_contact_section animation-element" data-section="contact-us">    
    <div class="container">
        <div class="small_contact_wrp side_animation_top">
            {% if section.settings.heading != blank %}
                <h2 class="contact_title">{{ section.settings.heading }}</h2>
            {% elsif settings.global_contact_heading != blank %}
                <h2 class="contact_title">{{ settings.heading }}</h2>
            {% endif %}

            {% if section.settings.address != blank or section.settings.phone_no != blank %}
            <div class="small_title_content">
                {{ section.settings.address }}
                <p><a href="tel:{{ section.settings.phone_no | replace: '(', '' | replace: ')', '' | replace: '-', '' | replace: ' ', '' }}">{{ section.settings.phone_no }}</a></p>
            </div>
            {% endif %}
            {% form 'contact',id: 'AjaxContactForm', class: 'contact_form' %}
                {% if form.errors %}
                <p class="form_error" style="color: red;">
                    {{ form.errors | default_errors }}
                </p>
                {% endif %}
                {% if form.posted_successfully? %}
                    <script type="text/javascript">
                        (function () {                        
                            window.openSuccessPopup = function () {                                   
                                const targetElement = document.querySelector('.form_contact_section');
                                const header = document.querySelector('.header');
                                const announcement = document.querySelector('.announcement_bar');

                                const headerHeight = header ? header.offsetHeight : 0;
                                const announcementHeight = announcement ? announcement.offsetHeight : 0;

                                const totalOffset = headerHeight + announcementHeight;

                                const elementTop =
                                    targetElement.getBoundingClientRect().top + window.pageYOffset;

                                window.scrollTo({
                                    top: elementTop - totalOffset,
                                    behavior: 'smooth'
                                }); 
                                
                                setTimeout(function(){ 
                                    document.querySelector('.contact-success-modal').style.display = 'block';
                                    document.querySelector('.contact-success-modal').style.opacity = 1;
                                    document.body.classList.add('ov_hi');
                                },200);
                                
                            };

                            document.querySelectorAll('.close_btn, .ok-btn').forEach(function (button) {
                                button.addEventListener('click', function () {
                                const modal = this.closest('.about_modal');
                                if (modal) {
                                    fadeOut(modal);
                                    clearURL();
                                }
                                });
                            });

                            // Close modal on outside click
                            window.addEventListener('click', function (e) {
                                if (e.target.classList.contains('about_modal')) {
                                fadeOut(e.target);
                                clearURL();
                                }
                            });

                            function fadeOut(element) {
                                let opacity = 1;
                                const fade = setInterval(function () {
                                opacity -= 0.1;
                                element.style.opacity = opacity;
                                if (opacity <= 0) {
                                    clearInterval(fade);
                                    element.style.display = 'none';
                                    document.body.classList.remove('ov_hi');
                                }
                                }, 20);
                            }

                            function clearURL() {
                                // Clear URL parameters
                                if (window.history.replaceState) {
                                    const url = window.location.pathname;
                                    window.history.replaceState({}, document.title, url);
                                }
                            }
                            
                            setTimeout(function(){            
                                window.openSuccessPopup();
                            },200);
                        })();
                    </script>
                    {% comment %} {% render 'contact-us-success-modal', section: section %} {% endcomment %}
                {% endif %}
                <div class="form_group">
                    <input type="text" 
                        name="contact[first_name]" 
                        value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.default_address.name }}{% endif %}"
                        placeholder="{{ 'sections.contact-us.placeholder.first_name' | t  }}"
                    >
                </div>
                <div class="form_group">
                    <input type="text" 
                        name="contact[last_name]" 
                        placeholder="{{ 'sections.contact-us.placeholder.last_name' | t  }}"
                    >
                </div>
                <div class="form_group {% unless section.settings.show_mob_phone %}desk_only{% endunless %}">
                    <input type="tel" 
                        name="contact[phone]" 
                        placeholder="{{ 'sections.contact-us.placeholder.phone_number' | t  }}"
                        value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.default_address.phone }}{% endif %}"
                        pattern="[0-9]+" 
                        inputmode="numeric" 
                        title="Please enter numbers only" 
                        oninput="this.value = this.value.replace(/[^0-9]/g, '')"                        
                    >
                </div>
                <div class="form_group">
                    <input 
                        autocomplete="email"
                        type="email" 
                        name="contact[email]" 
                        value="{% if customer %}{{ customer.default_address.email }}{% else %}{{ form.email }}{% endif %}" 
                        placeholder="{{ 'sections.contact-us.placeholder.email' | t  }}" 
                        required
                    >
                </div>
                <div class="form_group">
                    <select name="contact[area_of_concern]">
                        <option>{{ 'sections.contact-us.placeholder.area_of_concern' | t  }}</option>
                        {% assign concerns = settings.global_contact_concern | split: ',' %}
                        {% for item in concerns %}
                        {% assign trimmed = item | strip %}
                        <option value="{{ trimmed }}">{{ trimmed }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form_group">
                    <textarea
                        name="contact[comment]" 
                        placeholder="{{ 'sections.contact-us.message' | t  }}"
                        required
                    ></textarea>
                </div>
                <div class="checkbox_group">
                    <input type="checkbox" name="contact[permission]" id="checkbox" required>
                    <label for="checkbox">{{ 'sections.contact-us.checkbox_text' | t  }}</label>
                </div>
                <div class="form_group">
                    <input type="submit" value="{{ 'sections.contact-us.submit' | t  }}" class="btn btn_outlined">
                </div>
                {% comment %} <div class="contact_dropshadow"></div>                 {% endcomment %}
            {% endform %}            
        </div>
    </div>
    {% if section.settings.bg_image != blank %}
        <div class="form_contact_bg_image">
            <img src="{{ section.settings.bg_image | img_url:'master' }}" alt="{{ section.settings.bg_image.alt }}">
        </div>
    {% endif %}
</section>


{% schema %}
  {
    "name": "Contact us",    
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
            "type": "richtext",
            "id": "address",
            "label": "Address"
        },
        {
            "type": "text",
            "id": "phone_no",
            "label": "Phone number"
        },
        {
            "type": "checkbox",
            "id": "show_mob_phone",
            "label": "Show phone number in mobile screen?"
        },
        {
            "type": "image_picker",
            "id": "bg_image",
            "label": "Background Image"
        } 
    ],
    "presets": [
        {
            "name":"Contact us"
        }
    ]
  }
{% endschema %}